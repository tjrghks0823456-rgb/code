<Window x:Class="etch_ui.PresentationMotion.DemoEquipmentMotionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ETCH LOAD LOCK MOTION DEMO"
        Width="1680"
        Height="980"
        MinWidth="1440"
        MinHeight="860"
        WindowStartupLocation="CenterScreen"
        Background="#071019">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#101D29"/>
        <SolidColorBrush x:Key="Panel2Brush" Color="#0B1722"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#28465C"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EAF6FF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#86A7BA"/>
        <SolidColorBrush x:Key="CyanBrush" Color="#39D9FF"/>
        <SolidColorBrush x:Key="AmberBrush" Color="#FFC857"/>
        <SolidColorBrush x:Key="GoodBrush" Color="#4FE38A"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FF5A6A"/>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="8"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="StatusLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>

        <Style x:Key="StatusValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="DemoButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="98"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="#F6FBFF"/>
            <Setter Property="Background" Value="#17344A"/>
            <Setter Property="BorderBrush" Value="#3B6881"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ModuleLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F6FBFF"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="74"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="174"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="#0C1824"
                BorderBrush="#224B63"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18,0"
                Margin="8">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ETCH LOAD LOCK MOTION DEMO"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="31"
                               FontWeight="Bold"/>
                    <TextBlock Text="SEMI-style wafer pipeline | Queue -> Scheduler -> Dispatcher -> Resource Lock -> Module State Machine"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14"
                               Margin="2,3,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Border Background="#102B25"
                            BorderBrush="{StaticResource GoodBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,5"
                            Margin="0,0,10,0">
                        <TextBlock Text="SIMULATION MODE"
                                   Foreground="{StaticResource GoodBrush}"
                                   FontWeight="Bold"/>
                    </Border>
                    <Border Background="#0A2533"
                            BorderBrush="{StaticResource CyanBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,5">
                        <TextBlock x:Name="ClockText"
                                   Foreground="{StaticResource CyanBrush}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Text="00:00:00"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="PIPELINE CONTROL" Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Text="FOUP Slot Queue" Style="{StaticResource StatusLabelStyle}"/>
                    <Border Background="{StaticResource Panel2Brush}" BorderBrush="#25485D" BorderThickness="1" CornerRadius="8" Padding="10">
                        <TextBlock x:Name="SlotQueueText"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Scheduler" Style="{StaticResource StatusLabelStyle}"/>
                    <TextBlock x:Name="SchedulerDecisionText" Style="{StaticResource StatusValueStyle}" FontSize="16"/>

                    <TextBlock Text="Dispatcher" Style="{StaticResource StatusLabelStyle}"/>
                    <TextBlock x:Name="DispatcherStatusText" Style="{StaticResource StatusValueStyle}" FontSize="16"/>

                    <TextBlock Text="Resource Locks" Style="{StaticResource StatusLabelStyle}"/>
                    <Border Background="{StaticResource Panel2Brush}" BorderBrush="#25485D" BorderThickness="1" CornerRadius="8" Padding="10">
                        <TextBlock x:Name="ResourceLockText"
                                   Foreground="#CBEFFF"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Recipe / Vacuum" Style="{StaticResource StatusLabelStyle}"/>
                    <Border Background="{StaticResource Panel2Brush}" BorderBrush="#25485D" BorderThickness="1" CornerRadius="8" Padding="10">
                        <StackPanel>
                            <TextBlock x:Name="RecipeStatusText"
                                       Foreground="#EAF6FF"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="VacuumStatusText"
                                       Foreground="#9AC9DC"
                                       FontSize="13"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Module State Machines" Style="{StaticResource StatusLabelStyle}"/>
                    <ListBox x:Name="ModuleStateList"
                             MinHeight="156"
                             Background="#07131F"
                             BorderBrush="#25485D"
                             BorderThickness="1"
                             Foreground="#DCEFFF"
                             FontFamily="Consolas"
                             FontSize="13"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Padding="10">
            <Viewbox Stretch="Uniform">
                <Canvas x:Name="EquipmentCanvas" Width="1420" Height="760" ClipToBounds="True">
                    <Canvas.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#08121D" Offset="0"/>
                            <GradientStop Color="#10283A" Offset="1"/>
                        </LinearGradientBrush>
                    </Canvas.Background>

                    <Rectangle Canvas.Left="20" Canvas.Top="40" Width="1380" Height="680"
                               RadiusX="8" RadiusY="8"
                               Stroke="#1A4054"
                               StrokeThickness="2"
                               Fill="#07131F"/>

                    <TextBlock Canvas.Left="42" Canvas.Top="62"
                               Text="EFEM / Atmosphere"
                               Foreground="#70A8BD"
                               FontSize="17"
                               FontWeight="Bold"/>
                    <TextBlock Canvas.Left="658" Canvas.Top="62"
                               Text="Vacuum Transfer Module"
                               Foreground="#70A8BD"
                               FontSize="17"
                               FontWeight="Bold"/>
                    <Line X1="470" Y1="58" X2="470" Y2="704"
                          Stroke="#244A5F"
                          StrokeThickness="2"
                          StrokeDashArray="6,6"/>

                    <!-- FOUP and EFEM side -->
                    <Rectangle x:Name="FoupAModule"
                               Canvas.Left="58" Canvas.Top="145"
                               Width="170" Height="246"
                               RadiusX="8" RadiusY="8"
                               Fill="#162C3C"
                               Stroke="#5484A0"
                               StrokeThickness="2"/>
                    <TextBlock Canvas.Left="82" Canvas.Top="170" Width="122" Text="FOUP A" Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock Canvas.Left="91" Canvas.Top="199" Width="104" Text="Slots 01-05" Foreground="#9AC9DC" FontSize="13" TextAlignment="Center"/>
                    <Line X1="88" Y1="235" X2="198" Y2="235" Stroke="#355F76" StrokeThickness="2"/>
                    <Line X1="88" Y1="270" X2="198" Y2="270" Stroke="#355F76" StrokeThickness="2"/>
                    <Line X1="88" Y1="305" X2="198" Y2="305" Stroke="#355F76" StrokeThickness="2"/>
                    <Line X1="88" Y1="340" X2="198" Y2="340" Stroke="#355F76" StrokeThickness="2"/>

                    <Rectangle x:Name="FoupReturnModule"
                               Canvas.Left="58" Canvas.Top="477"
                               Width="170" Height="154"
                               RadiusX="8" RadiusY="8"
                               Fill="#162C3C"
                               Stroke="#5484A0"
                               StrokeThickness="2"/>
                    <TextBlock Canvas.Left="82" Canvas.Top="515" Width="122" Text="FOUP Return" Style="{StaticResource ModuleLabelStyle}" FontSize="15"/>
                    <TextBlock Canvas.Left="88" Canvas.Top="548" Width="110" Text="Unload Slots" Foreground="#9AC9DC" FontSize="13" TextAlignment="Center"/>

                    <Rectangle x:Name="AlignerModule"
                               Canvas.Left="294" Canvas.Top="210"
                               Width="160" Height="136"
                               RadiusX="8" RadiusY="8"
                               Fill="#162C3C"
                               Stroke="#5484A0"
                               StrokeThickness="2"/>
                    <TextBlock Canvas.Left="318" Canvas.Top="252" Width="112" Text="Aligner" Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock Canvas.Left="320" Canvas.Top="284" Width="108" Text="Orient / Buffer" Foreground="#9AC9DC" FontSize="13" TextAlignment="Center"/>

                    <Rectangle x:Name="BufferModule"
                               Canvas.Left="294" Canvas.Top="442"
                               Width="160" Height="116"
                               RadiusX="8" RadiusY="8"
                               Fill="#142838"
                               Stroke="#416B82"
                               StrokeThickness="2"/>
                    <TextBlock Canvas.Left="318" Canvas.Top="474" Width="112" Text="Buffer Stage" Style="{StaticResource ModuleLabelStyle}" FontSize="15"/>
                    <TextBlock Canvas.Left="318" Canvas.Top="505" Width="112" Text="pre-stage" Foreground="#9AC9DC" FontSize="13" TextAlignment="Center"/>

                    <Rectangle x:Name="LoadLockModule"
                               Canvas.Left="536" Canvas.Top="278"
                               Width="176" Height="168"
                               RadiusX="8" RadiusY="8"
                               Fill="#182F3D"
                               Stroke="#72A9C4"
                               StrokeThickness="2"/>
                    <Rectangle x:Name="LoadLockDoor"
                               Canvas.Left="524" Canvas.Top="309"
                               Width="10" Height="106"
                               RadiusX="3" RadiusY="3"
                               Fill="{StaticResource ErrorBrush}"/>
                    <TextBlock Canvas.Left="564" Canvas.Top="318" Width="118" Text="Load Lock" Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock x:Name="DoorStatusText"
                               Canvas.Left="566" Canvas.Top="354"
                               Width="116"
                               Text="DOOR CLOSED"
                               Foreground="#FF8A96"
                               FontSize="12"
                               FontWeight="Bold"
                               TextAlignment="Center"/>
                    <TextBlock Canvas.Left="566" Canvas.Top="382"
                               Width="116"
                               Text="ATM / VAC"
                               Foreground="#9AC9DC"
                               FontSize="13"
                               TextAlignment="Center"/>

                    <!-- Vacuum transfer robot -->
                    <Ellipse Canvas.Left="705" Canvas.Top="175" Width="360" Height="360"
                             Stroke="#20485F"
                             StrokeThickness="3"
                             Fill="#0A1927"/>
                    <Ellipse Canvas.Left="825" Canvas.Top="295" Width="120" Height="120"
                             Stroke="#4C778D"
                             StrokeThickness="2"
                             Fill="#132D40"/>
                    <TextBlock Canvas.Left="790" Canvas.Top="432"
                               Width="190"
                               Text="Transfer Robot"
                               Foreground="#9AC9DC"
                               FontSize="16"
                               FontWeight="Bold"
                               TextAlignment="Center"/>
                    <Line x:Name="RobotArmLine"
                          X1="885" Y1="355"
                          X2="1065" Y2="355"
                          Stroke="{StaticResource AmberBrush}"
                          StrokeThickness="13"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round">
                        <Line.RenderTransform>
                            <RotateTransform x:Name="RobotArmRotateTransform"
                                             Angle="180"
                                             CenterX="885"
                                             CenterY="355"/>
                        </Line.RenderTransform>
                    </Line>
                    <Ellipse Canvas.Left="868" Canvas.Top="338" Width="34" Height="34"
                             Fill="#FFC857"
                             Stroke="#FFE7A6"
                             StrokeThickness="2"/>

                    <!-- Process modules spread around the robot -->
                    <Rectangle x:Name="PM1Module"
                               Canvas.Left="684" Canvas.Top="74"
                               Width="178" Height="128"
                               RadiusX="8" RadiusY="8"
                               Fill="#152B3A"
                               Stroke="#567F96"
                               StrokeThickness="2"/>
                    <Rectangle x:Name="PM1ProgressFill" Canvas.Left="702" Canvas.Top="178" Width="0" Height="10" Fill="{StaticResource GoodBrush}"/>
                    <TextBlock Canvas.Left="710" Canvas.Top="106" Width="126" Text="PM1 Strip" Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock Canvas.Left="714" Canvas.Top="140" Width="118" Text="Strip Recipe" Foreground="#83AEC1" FontSize="13" TextAlignment="Center"/>

                    <Rectangle x:Name="PM2Module"
                               Canvas.Left="954" Canvas.Top="74"
                               Width="178" Height="128"
                               RadiusX="8" RadiusY="8"
                               Fill="#152B3A"
                               Stroke="#567F96"
                               StrokeThickness="2"/>
                    <Rectangle x:Name="PM2ProgressFill" Canvas.Left="972" Canvas.Top="178" Width="0" Height="10" Fill="{StaticResource GoodBrush}"/>
                    <TextBlock Canvas.Left="980" Canvas.Top="106" Width="126" Text="PM2 Etch" Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock Canvas.Left="984" Canvas.Top="140" Width="118" Text="Etch Recipe A" Foreground="#83AEC1" FontSize="13" TextAlignment="Center"/>

                    <Rectangle x:Name="PM3Module"
                               Canvas.Left="1190" Canvas.Top="285"
                               Width="178" Height="128"
                               RadiusX="8" RadiusY="8"
                               Fill="#152B3A"
                               Stroke="#567F96"
                               StrokeThickness="2"/>
                    <Rectangle x:Name="PM3ProgressFill" Canvas.Left="1208" Canvas.Top="389" Width="0" Height="10" Fill="{StaticResource GoodBrush}"/>
                    <TextBlock Canvas.Left="1216" Canvas.Top="317" Width="126" Text="PM3 Etch" Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock Canvas.Left="1220" Canvas.Top="351" Width="118" Text="Etch Recipe B" Foreground="#83AEC1" FontSize="13" TextAlignment="Center"/>

                    <Rectangle x:Name="PM4Module"
                               Canvas.Left="954" Canvas.Top="548"
                               Width="178" Height="128"
                               RadiusX="8" RadiusY="8"
                               Fill="#152B3A"
                               Stroke="#567F96"
                               StrokeThickness="2"/>
                    <Rectangle x:Name="PM4ProgressFill" Canvas.Left="972" Canvas.Top="652" Width="0" Height="10" Fill="{StaticResource GoodBrush}"/>
                    <TextBlock Canvas.Left="980" Canvas.Top="580" Width="126" Text="PM4 Etch" Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock Canvas.Left="984" Canvas.Top="614" Width="118" Text="Etch Recipe C" Foreground="#83AEC1" FontSize="13" TextAlignment="Center"/>

                    <Rectangle x:Name="SideStorageModule"
                               Canvas.Left="1190" Canvas.Top="548"
                               Width="178" Height="128"
                               RadiusX="8" RadiusY="8"
                               Fill="#162C3C"
                               Stroke="#5484A0"
                               StrokeThickness="2"/>
                    <TextBlock Canvas.Left="1214" Canvas.Top="591" Width="130" Text="Side Storage" Style="{StaticResource ModuleLabelStyle}" FontSize="16"/>

                    <Path Stroke="#244A5F"
                          StrokeThickness="4"
                          StrokeDashArray="7,7"
                          Data="M 143 268 L 374 278 L 624 362 L 885 355 L 1043 138
                                M 885 355 L 1279 349
                                M 885 355 L 1043 612
                                M 885 355 L 773 138
                                M 624 362 L 374 500 L 143 554"/>

                    <Ellipse x:Name="WaferEllipse"
                             Canvas.Left="125" Canvas.Top="250"
                             Width="36" Height="36"
                             Stroke="#EFFFFF"
                             StrokeThickness="2">
                        <Ellipse.Fill>
                            <RadialGradientBrush GradientOrigin="0.35,0.3">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#9CEBFF" Offset="0.52"/>
                                <GradientStop Color="#3AA7D7" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#4AE7FF" BlurRadius="18" ShadowDepth="0" Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <Ellipse x:Name="RobotCarrierGlow"
                             Canvas.Left="1048" Canvas.Top="338"
                             Width="36" Height="36"
                             Stroke="#FFE7A6"
                             StrokeThickness="2"
                             Fill="#30FFC857"
                             Opacity="0.7"/>
                </Canvas>
            </Viewbox>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="STATUS PANEL" Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Text="Equipment State" Style="{StaticResource StatusLabelStyle}"/>
                    <TextBlock x:Name="EquipmentStateText" Text="IDLE" Style="{StaticResource StatusValueStyle}"/>

                    <TextBlock Text="Current Step" Style="{StaticResource StatusLabelStyle}"/>
                    <TextBlock x:Name="CurrentStepText" Text="Ready" Style="{StaticResource StatusValueStyle}" FontSize="17"/>

                    <TextBlock Text="Current Wafer Location" Style="{StaticResource StatusLabelStyle}"/>
                    <TextBlock x:Name="WaferLocationText" Text="FOUP A Slot 01" Style="{StaticResource StatusValueStyle}" FontSize="17"/>

                    <TextBlock Text="Active Module" Style="{StaticResource StatusLabelStyle}"/>
                    <TextBlock x:Name="ActiveModuleText" Text="None" Style="{StaticResource StatusValueStyle}" FontSize="17"/>

                    <TextBlock Text="Chamber Progress" Style="{StaticResource StatusLabelStyle}"/>
                    <ProgressBar x:Name="ChamberProgressBar"
                                 Height="22"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Foreground="{StaticResource GoodBrush}"
                                 Background="#07131F"
                                 BorderBrush="#345A72"
                                 BorderThickness="1"/>
                    <TextBlock x:Name="ChamberProgressText"
                               Text="0%"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0"/>

                    <TextBlock Text="Robot Status" Style="{StaticResource StatusLabelStyle}"/>
                    <TextBlock x:Name="RobotStatusText" Text="Standby" Style="{StaticResource StatusValueStyle}" FontSize="17"/>

                    <TextBlock Text="Interlock Status" Style="{StaticResource StatusLabelStyle}"/>
                    <Border BorderBrush="#34694D"
                            BorderThickness="1"
                            Background="#0D2C21"
                            CornerRadius="8"
                            Padding="10,6"
                            Margin="0,0,0,12">
                        <TextBlock x:Name="InterlockStatusText"
                                   Text="DISPLAY ONLY - VAC / DOOR / ROBOT OK"
                                   Foreground="{StaticResource GoodBrush}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Training GUI Signals" Style="{StaticResource StatusLabelStyle}"/>
                    <Border Background="{StaticResource Panel2Brush}"
                            BorderBrush="#25485D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="58"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>

                            <Ellipse x:Name="SignalRobotReadyLamp" Width="12" Height="12" Fill="#4FE38A" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Robot Ready" Foreground="#DCEFFF" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SignalRobotReadyText" Grid.Column="2" Text="ON" Foreground="#4FE38A" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                            <Ellipse x:Name="SignalVacuumLamp" Grid.Row="1" Width="12" Height="12" Fill="#4FE38A" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Vacuum OK" Foreground="#DCEFFF" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SignalVacuumText" Grid.Row="1" Grid.Column="2" Text="ON" Foreground="#4FE38A" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                            <Ellipse x:Name="SignalDoorLamp" Grid.Row="2" Width="12" Height="12" Fill="#FF5A6A" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="LL Door Open" Foreground="#DCEFFF" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SignalDoorText" Grid.Row="2" Grid.Column="2" Text="OFF" Foreground="#FF8A96" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                            <Ellipse x:Name="SignalWaferLamp" Grid.Row="3" Width="12" Height="12" Fill="#4FE38A" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Wafer Present" Foreground="#DCEFFF" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SignalWaferText" Grid.Row="3" Grid.Column="2" Text="ON" Foreground="#4FE38A" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                            <Ellipse x:Name="SignalFaultLamp" Grid.Row="4" Width="12" Height="12" Fill="#315064" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Alarm / Fault" Foreground="#DCEFFF" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SignalFaultText" Grid.Row="4" Grid.Column="2" Text="OFF" Foreground="#86A7BA" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="Operation Guide" Style="{StaticResource StatusLabelStyle}"/>
                    <Border Background="#091622"
                            BorderBrush="#25485D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,12">
                        <TextBlock Text="교육용 GUI처럼 슬롯 예약, 수동 신호, 인터락 표시, 공정 진행 상태를 한 화면에서 확인합니다. 실제 제어 출력은 발생하지 않습니다."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <WrapPanel Margin="0,12,0,0">
                        <Button x:Name="StartDemoButton" Content="Start Demo" Style="{StaticResource DemoButtonStyle}" Click="StartDemo_Click"/>
                        <Button x:Name="PauseButton" Content="Pause" Style="{StaticResource DemoButtonStyle}" Click="Pause_Click"/>
                        <Button Content="Reset" Style="{StaticResource DemoButtonStyle}" Click="Reset_Click"/>
                        <Button Content="Inject Error" Style="{StaticResource DemoButtonStyle}" Background="#4A1D2A" BorderBrush="#8C4555" Click="InjectError_Click"/>
                        <Button Content="Clear Error" Style="{StaticResource DemoButtonStyle}" Click="ClearError_Click"/>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="EVENT LOG" Style="{StaticResource SectionTitleStyle}"/>
                <ListBox x:Name="EventLogList"
                         Grid.Row="1"
                         Background="#07131F"
                         BorderBrush="#25485D"
                         BorderThickness="1"
                         Foreground="#DCEFFF"
                         FontFamily="Consolas"
                         FontSize="14"
                         Padding="8"/>
            </Grid>
        </Border>
