<Window x:Class="etch_ui.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="로그인 — Etch HMI"
        Width="460"
        MinWidth="440"
        MinHeight="520"
        MaxHeight="900"
        SizeToContent="Height"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource HmiFont}"
        Background="{StaticResource HmiCanvasBrush}">
    <Border Margin="20" Style="{StaticResource HmiCard}" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource HmiHeaderBrush}" CornerRadius="10,10,0,0" Padding="24,20">
                <StackPanel>
                    <TextBlock Text="ETCH LOAD LOCK HMI" Foreground="#64748B" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock Text="장비 제어 시스템 로그인" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock Text="승인된 계정으로 로그인하세요." Foreground="#94A3B8" FontSize="12" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="28,24,28,8">
                <TextBlock Text="아이디" Style="{StaticResource HmiCaption}" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtUsername" Style="{StaticResource HmiTextBox}"/>

                <TextBlock Text="비밀번호" Style="{StaticResource HmiCaption}" Margin="0,16,0,6"/>
                <PasswordBox x:Name="TxtPassword" Style="{StaticResource HmiPasswordBox}"/>

                <TextBlock x:Name="TxtError"
                           Foreground="#DC2626"
                           TextWrapping="Wrap"
                           MinHeight="22"
                           Margin="0,14,0,0"
                           FontSize="13"/>

                <Border Style="{StaticResource HmiInfoBanner}" Background="#F8FAFC" BorderBrush="{StaticResource HmiBorderBrush}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="안내" FontWeight="SemiBold" Foreground="{StaticResource HmiTextPrimaryBrush}" FontSize="12"/>
                        <TextBlock Text="• 비밀번호: 최소 8자, 영문과 숫자 포함" Style="{StaticResource HmiCardSubtitle}" Margin="0,4,0,0"/>
                        <TextBlock Text="• 관리자: 알람 리셋·유지보수·사용자 관리" Style="{StaticResource HmiCardSubtitle}" Margin="0,2,0,0"/>
                        <TextBlock Text="• 작업자: 모니터링·Start/Stop" Style="{StaticResource HmiCardSubtitle}" Margin="0,2,0,0"/>
                        <TextBlock Text="• 초기 계정 — admin / Admin1234 · worker / Worker1234" Style="{StaticResource HmiCardSubtitle}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="2" BorderBrush="{StaticResource HmiBorderBrush}" BorderThickness="0,1,0,0" Padding="24,16,24,20">
                <StackPanel>
                    <Button x:Name="BtnLogin" Content="로그인" Height="44" Style="{StaticResource HmiPrimaryButton}"
                            IsDefault="True" Click="BtnLogin_Click"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnClear" Grid.Column="0" Content="입력 지우기" Height="38" Margin="0,0,6,0"
                                Style="{StaticResource HmiSecondaryButton}" Click="BtnClear_Click"/>
                        <Button x:Name="BtnCancel" Grid.Column="1" Content="취소" Height="38" Margin="6,0,0,0"
                                Style="{StaticResource HmiSecondaryButton}" IsCancel="True"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
