<Window x:Class="etch_ui.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="사용자 관리"
        Height="560"
        Width="560"
        MinHeight="520"
        MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F3F4F6">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="사용자 등록 · 계정 관리" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
            <TextBlock Text="관리자만 접근할 수 있습니다. 작업자는 모니터링·운전(Start/Stop)만 가능합니다."
                       Foreground="#6B7280" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12" BorderBrush="#E5E7EB" BorderThickness="1">
            <DataGrid x:Name="GrdUsers"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F9FAFB">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="아이디" Binding="{Binding Username}" Width="*"/>
                    <DataGridTextColumn Header="역할" Binding="{Binding RoleDisplay}" Width="90"/>
                    <DataGridTextColumn Header="상태" Binding="{Binding StatusDisplay}" Width="70"/>
                    <DataGridTextColumn Header="등록일" Binding="{Binding CreatedAt}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="14" Margin="0,14,0,0" BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="신규 아이디" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtNewUsername" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="비밀번호" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="TxtNewPassword" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="비밀번호 확인" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="TxtNewPasswordConfirm" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="역할" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="CmbNewRole" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" x:Name="TxtRegisterMsg" Foreground="#DC2626" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnToggleActive" Content="선택 계정 사용/비활성 전환" Padding="14,8" Margin="0,0,10,0" Click="BtnToggleActive_Click"/>
            <Button x:Name="BtnRegister" Content="회원 등록" Padding="20,8" Margin="0,0,10,0" Click="BtnRegister_Click"/>
            <Button Content="닫기" Padding="18,8" IsCancel="True" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
