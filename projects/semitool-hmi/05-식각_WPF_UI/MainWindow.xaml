<Window x:Class="etch_ui.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        mc:Ignorable="d"

        Title="Etch Load Lock HMI"

        Height="740"

        Width="1180"

        MinHeight="700"

        MinWidth="1100">

    <Grid Margin="12">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="2*"/>

            <ColumnDefinition Width="2*"/>

            <ColumnDefinition Width="3*"/>

        </Grid.ColumnDefinitions>



        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#1F2937" CornerRadius="8" Padding="12" Margin="0,0,0,10">

            <DockPanel>

                <TextBlock Text="플라즈마 식각 장비 Load Lock/챔버 상태 관리 HMI"

                           Foreground="White"

                           FontSize="18"

                           FontWeight="Bold"

                           DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">

                    <TextBlock Text="사용자: " Foreground="White" VerticalAlignment="Center"/>

                    <TextBlock Text="{Binding CurrentUserText}" Foreground="#D1FAE5" FontWeight="Bold" VerticalAlignment="Center"/>

                    <Button x:Name="BtnUserManage" Content="사용자 관리" Margin="8,0,8,0" Padding="8,2" Click="BtnUserManage_Click"

                            Visibility="{Binding ShowUserManage, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button x:Name="BtnLogout" Content="로그아웃" Margin="0,0,14,0" Padding="8,2" Click="BtnLogout_Click"/>

                    <TextBlock Text="Flask: " Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0"/>

                    <TextBlock Text="{Binding FlaskStatusText}" Foreground="{Binding FlaskStatusBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>

                    <TextBlock Text="PLC: " Foreground="White" VerticalAlignment="Center"/>

                    <TextBlock Text="{Binding PlcStatusText}" Foreground="{Binding PlcStatusBrush}" FontWeight="Bold" VerticalAlignment="Center"/>

                    <Button x:Name="BtnSimAllow" Content="{Binding SimAllowButtonText}" Margin="10,0,0,0" Padding="8,2" VerticalAlignment="Center"

                            Click="BtnSimAllow_Click"

                            ToolTip="켜두면 PLC 끊김 시 데모용 시뮬 센서로 대체합니다. 실기만 사용할 때는 끄세요."/>

                    <TextBlock Text="   마지막 갱신: " Foreground="White" VerticalAlignment="Center"/>

                    <TextBlock Text="{Binding LastUpdateText}" Foreground="#D1D5DB" VerticalAlignment="Center"/>

                    <TextBlock Text="  | 데이터: " Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0"/>

                    <TextBlock Text="{Binding DataQualityText}" Foreground="{Binding DataQualityBrush}" VerticalAlignment="Center"

                               ToolTip="PLC ADS 마지막 성공 읽기 또는 시뮬/오프라인 표시"/>

                </StackPanel>

            </DockPanel>

        </Border>



        <GroupBox Grid.Row="1" Grid.Column="0" Header="장비 상태" Margin="0,0,10,10" Padding="10">

            <StackPanel>

                <TextBlock Text="현재 상태" FontWeight="SemiBold" Margin="0,0,0,6"/>

                <TextBlock Text="{Binding StateText}" FontSize="28" FontWeight="Bold" Foreground="{Binding StateBrush}"/>

                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">

                    <TextBlock Text="알람: " FontWeight="SemiBold" VerticalAlignment="Center"/>

                    <TextBlock Text="{Binding AlarmCodeText}" Foreground="{Binding AlarmCodeBrush}" VerticalAlignment="Center"/>

                </StackPanel>

                <TextBlock Text="{Binding AlarmDetailText}" TextWrapping="Wrap" Margin="0,8,0,0" FontSize="12"

                           Foreground="{Binding AlarmDetailBrush}" LineHeight="18"/>



                <UniformGrid Columns="2" Margin="0,12,0,0">

                    <StackPanel Margin="0,0,12,8">

                        <TextBlock Text="온도(℃)" FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding TemperatureText}"/>

                    </StackPanel>

                    <StackPanel Margin="0,0,0,8">

                        <TextBlock Text="습도(%)" FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding HumidityText}"/>

                    </StackPanel>

                    <StackPanel Margin="0,0,12,8">

                        <TextBlock Text="압력(kPa)" FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding PressureText}" FontSize="16" FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding PressureDetailText}" FontSize="10" Foreground="#6B7280" TextWrapping="Wrap"/>

                    </StackPanel>

                    <StackPanel Margin="0,0,0,8">

                        <TextBlock Text="진동(g)" FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding VibrationText}"/>

                    </StackPanel>

                </UniformGrid>



                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">

                    <TextBlock Text="접근 센서: " FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding AccessText}" Foreground="{Binding AccessBrush}" FontWeight="Bold"/>

                </StackPanel>

            </StackPanel>

        </GroupBox>



        <GroupBox Grid.Row="1" Grid.Column="1" Header="인터락 / 공정 위치" Margin="0,0,10,10" Padding="10">

            <StackPanel>

                <TextBlock Text="공정 단계(개요)" FontWeight="SemiBold" Margin="0,0,0,6"/>

                <TextBlock Text="{Binding ProcessPhaseText}" FontSize="14" Foreground="#1E3A8A"/>

                <TextBlock Text="실제 PLC 스텝 심볼 연동 전까지 상태·인터락 기반으로 표시합니다." FontSize="11" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,4,0,12"/>



                <TextBlock Text="인터락(임계: appsettings.json)" FontWeight="SemiBold" Margin="0,0,0,6"/>

                <TextBlock Text="{Binding InterlockPlcText}" Margin="0,0,0,6"/>

                <TextBlock Text="{Binding InterlockPressureText}" Margin="0,0,0,6"/>

                <TextBlock Text="{Binding InterlockVibText}" Margin="0,0,0,6"/>

                <TextBlock Text="{Binding InterlockAccessText}" Margin="0,0,0,6"/>

                <TextBlock Text="{Binding InterlockTempText}" Margin="0,0,0,6"/>

                <TextBlock Text="{Binding InterlockHumiText}" Margin="0,0,0,10"/>



                <Border Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" Padding="8" CornerRadius="6">

                    <StackPanel>

                        <TextBlock Text="판정 결과" FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding InterlockResultText}" Foreground="{Binding InterlockResultBrush}" Margin="0,4,0,0" FontWeight="SemiBold"/>

                    </StackPanel>

                </Border>

            </StackPanel>

        </GroupBox>



        <GroupBox Grid.Row="1" Grid.Column="2" Header="상태 램프 / 제어" Margin="0,0,0,10" Padding="10">

            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>



                <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,10">

                    <Border CornerRadius="6" Margin="4" Padding="8"

                            Background="{Binding LampReadyOn, Converter={StaticResource LampBrush}, ConverterParameter=Blue}">

                        <TextBlock Text="READY" HorizontalAlignment="Center"/>

                    </Border>

                    <Border CornerRadius="6" Margin="4" Padding="8"

                            Background="{Binding LampRunOn, Converter={StaticResource LampBrush}, ConverterParameter=Green}">

                        <TextBlock Text="RUNNING" HorizontalAlignment="Center"/>

                    </Border>

                    <Border CornerRadius="6" Margin="4" Padding="8"

                            Background="{Binding LampWarnOn, Converter={StaticResource LampBrush}, ConverterParameter=Gold}">

                        <TextBlock Text="WARNING" HorizontalAlignment="Center"/>

                    </Border>

                    <Border CornerRadius="6" Margin="4" Padding="8"

                            Background="{Binding LampAlarmOn, Converter={StaticResource LampBrush}, ConverterParameter=Red}">

                        <TextBlock Text="ALARM" HorizontalAlignment="Center"/>

                    </Border>

                </UniformGrid>



                <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,10">

                    <Button x:Name="BtnStart" Content="Start" Margin="4" Padding="8" Click="BtnStart_Click"

                            IsEnabled="{Binding CanStart}"/>

                    <Button x:Name="BtnStop" Content="Stop" Margin="4" Padding="8" Click="BtnStop_Click"

                            IsEnabled="{Binding CanStop}"/>

                    <Button x:Name="BtnReset" Content="Alarm Reset" Margin="4" Padding="8" Click="BtnReset_Click"

                            IsEnabled="{Binding CanReset}"/>

                    <Button x:Name="BtnMaint" Content="Maintenance" Margin="4" Padding="8" Click="BtnMaint_Click"

                            IsEnabled="{Binding CanMaint}"/>

                </UniformGrid>



                <GroupBox Grid.Row="2" Header="알람 / 로그(최근)" Padding="8">

                    <ListBox ItemsSource="{Binding LogLines}"/>

                </GroupBox>

            </Grid>

        </GroupBox>



        <TextBlock Grid.Row="2" Grid.ColumnSpan="3"

                   Foreground="#6B7280"

                   Text="현장 운전/안전 HMI · 원격 모니터링·이력은 Flask 웹 대시보드에서 확인합니다."/>

    </Grid>

</Window>


