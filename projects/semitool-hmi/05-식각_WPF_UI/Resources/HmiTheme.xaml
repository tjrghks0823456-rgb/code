<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Palette -->
    <Color x:Key="HmiPrimaryColor">#2563EB</Color>
    <Color x:Key="HmiPrimaryDarkColor">#1E40AF</Color>
    <Color x:Key="HmiSurfaceColor">#FFFFFF</Color>
    <Color x:Key="HmiCanvasColor">#E8EDF3</Color>
    <Color x:Key="HmiHeaderColor">#0F172A</Color>
    <Color x:Key="HmiHeaderAccentColor">#1E293B</Color>
    <Color x:Key="HmiTextPrimaryColor">#0F172A</Color>
    <Color x:Key="HmiTextSecondaryColor">#64748B</Color>
    <Color x:Key="HmiBorderColor">#E2E8F0</Color>
    <Color x:Key="HmiSuccessColor">#16A34A</Color>
    <Color x:Key="HmiDangerColor">#DC2626</Color>
    <Color x:Key="HmiWarningColor">#D97706</Color>

    <SolidColorBrush x:Key="HmiPrimaryBrush" Color="{StaticResource HmiPrimaryColor}"/>
    <SolidColorBrush x:Key="HmiPrimaryDarkBrush" Color="{StaticResource HmiPrimaryDarkColor}"/>
    <SolidColorBrush x:Key="HmiSurfaceBrush" Color="{StaticResource HmiSurfaceColor}"/>
    <SolidColorBrush x:Key="HmiCanvasBrush" Color="{StaticResource HmiCanvasColor}"/>
    <SolidColorBrush x:Key="HmiHeaderBrush" Color="{StaticResource HmiHeaderColor}"/>
    <SolidColorBrush x:Key="HmiTextPrimaryBrush" Color="{StaticResource HmiTextPrimaryColor}"/>
    <SolidColorBrush x:Key="HmiTextSecondaryBrush" Color="{StaticResource HmiTextSecondaryColor}"/>
    <SolidColorBrush x:Key="HmiBorderBrush" Color="{StaticResource HmiBorderColor}"/>

    <FontFamily x:Key="HmiFont">Segoe UI, Malgun Gothic, sans-serif</FontFamily>
    <FontFamily x:Key="HmiMonoFont">Cascadia Mono, Consolas, monospace</FontFamily>

  <!-- Panel card (replaces GroupBox) -->
    <Style x:Key="HmiCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HmiSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HmiBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#1A000000" BlurRadius="12" ShadowDepth="2" Opacity="0.12"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HmiCardHeader" TargetType="Border">
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="{StaticResource HmiBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10,10,0,0"/>
    </Style>

    <Style x:Key="HmiCardTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource HmiTextPrimaryBrush}"/>
    </Style>

    <Style x:Key="HmiCardSubtitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource HmiTextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>

    <Style x:Key="HmiCardBody" TargetType="FrameworkElement">
        <Setter Property="Margin" Value="14"/>
    </Style>

    <Style x:Key="HmiCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource HmiTextSecondaryBrush}"/>
    </Style>

    <Style x:Key="HmiMetricTile" TargetType="Border">
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="{StaticResource HmiBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Margin" Value="0,0,8,8"/>
    </Style>

    <Style x:Key="HmiMetricLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource HmiTextSecondaryBrush}"/>
    </Style>

    <Style x:Key="HmiMetricValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource HmiTextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <!-- Header toolbar -->
    <Style x:Key="HmiToolbarButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#E2E8F0"/>
        <Setter Property="Background" Value="#334155"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Margin" Value="4,0,0,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#475569"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#1E293B"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HmiToolbarButtonPrimary" TargetType="Button" BasedOn="{StaticResource HmiToolbarButton}">
        <Setter Property="Background" Value="{StaticResource HmiPrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="HmiStatusChip" TargetType="Border">
        <Setter Property="Background" Value="#1E293B"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="HmiStatusChipLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#94A3B8"/>
    </Style>

    <Style x:Key="HmiStatusChipValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#F1F5F9"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>

    <!-- Control panel buttons -->
    <Style x:Key="HmiControlButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,14"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="#CBD5E1"/>
                            <Setter Property="Foreground" Value="#94A3B8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HmiBtnStart" TargetType="Button" BasedOn="{StaticResource HmiControlButton}">
        <Setter Property="Background" Value="#16A34A"/>
    </Style>
    <Style x:Key="HmiBtnStop" TargetType="Button" BasedOn="{StaticResource HmiControlButton}">
        <Setter Property="Background" Value="#DC2626"/>
    </Style>
    <Style x:Key="HmiBtnReset" TargetType="Button" BasedOn="{StaticResource HmiControlButton}">
        <Setter Property="Background" Value="#D97706"/>
    </Style>
    <Style x:Key="HmiBtnMaint" TargetType="Button" BasedOn="{StaticResource HmiControlButton}">
        <Setter Property="Background" Value="#6366F1"/>
    </Style>

    <Style x:Key="HmiLampPanel" TargetType="Border">
        <Setter Property="Background" Value="#0F172A"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <Style x:Key="HmiLampCell" TargetType="Border">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8,10"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="MinHeight" Value="44"/>
    </Style>

    <Style x:Key="HmiLampText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="HmiInfoBanner" TargetType="Border">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="HmiLogList" TargetType="ListBox">
        <Setter Property="FontFamily" Value="{StaticResource HmiMonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="Padding" Value="4"/>
    </Style>

    <!-- Dialog / secondary windows -->
    <Style x:Key="HmiTextBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="{StaticResource HmiBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="HmiPasswordBox" TargetType="PasswordBox">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="{StaticResource HmiBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="HmiPrimaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource HmiPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource HmiPrimaryDarkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HmiSecondaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource HmiTextPrimaryBrush}"/>
        <Setter Property="Background" Value="#F1F5F9"/>
        <Setter Property="BorderBrush" Value="{StaticResource HmiBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#E2E8F0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HmiDataGrid" TargetType="DataGrid">
        <Setter Property="FontFamily" Value="{StaticResource HmiFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="RowBackground" Value="White"/>
        <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource HmiBorderBrush}"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
    </Style>

    <Style x:Key="HmiChartPanel" TargetType="Border">
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="{StaticResource HmiBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

</ResourceDictionary>
