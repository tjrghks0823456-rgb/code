<Window x:Class="etch_ui.PresentationMotion.DemoEquipmentMotionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ETCH LOAD LOCK MOTION DEMO"
        Width="1480"
        Height="920"
        MinWidth="1280"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#071019">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#101D29"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#28465C"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EAF6FF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#86A7BA"/>
        <SolidColorBrush x:Key="CyanBrush" Color="#39D9FF"/>
        <SolidColorBrush x:Key="AmberBrush" Color="#FFC857"/>
        <SolidColorBrush x:Key="GoodBrush" Color="#4FE38A"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FF5A6A"/>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="8"/>
        </Style>

        <Style x:Key="StatusLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,2"/>
        </Style>

        <Style x:Key="StatusValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="21"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="DemoButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="#F6FBFF"/>
            <Setter Property="Background" Value="#17344A"/>
            <Setter Property="BorderBrush" Value="#3B6881"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ModuleLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F6FBFF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="74"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#0C1824"
                BorderBrush="#224B63"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18,0"
                Margin="8">
            <Grid>
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="ETCH LOAD LOCK MOTION DEMO"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="31"
                               FontWeight="Bold"/>
                    <TextBlock Text="FOUP A -> Aligner -> Load Lock -> PM2 -> PM3 -> PM4 -> PM1 -> FOUP Return"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14"
                               Margin="2,3,0,0"/>
                </StackPanel>
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="#0A2533"
                        BorderBrush="{StaticResource CyanBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14,5">
                    <TextBlock x:Name="ClockText"
                               Foreground="{StaticResource CyanBrush}"
                               FontSize="15"
                               FontWeight="Bold"
                               Text="00:00:00"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
            <Viewbox Stretch="Uniform">
                <Canvas x:Name="EquipmentCanvas" Width="1000" Height="620" ClipToBounds="True">
                    <Canvas.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#08121D" Offset="0"/>
                            <GradientStop Color="#10283A" Offset="1"/>
                        </LinearGradientBrush>
                    </Canvas.Background>

                    <TextBlock Canvas.Left="30" Canvas.Top="18"
                               Text="Presentation-only motion visualization"
                               Foreground="#668EA3"
                               FontSize="15"/>

                    <Rectangle Canvas.Left="20" Canvas.Top="58" Width="960" Height="520"
                               RadiusX="14" RadiusY="14"
                               Stroke="#1A4054"
                               StrokeThickness="2"
                               Fill="#07131F"/>

                    <!-- EFEM side -->
                    <Rectangle x:Name="FoupAModule"
                               Canvas.Left="52" Canvas.Top="215"
                               Width="128" Height="126"
                               RadiusX="10" RadiusY="10"
                               Fill="#162C3C"
                               Stroke="#5484A0"
                               StrokeThickness="2"/>
                    <TextBlock Canvas.Left="78" Canvas.Top="240"
                               Width="76"
                               Text="FOUP A"
                               Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock Canvas.Left="75" Canvas.Top="270"
                               Width="82"
                               Text="LOAD"
                               Foreground="#9AC9DC"
                               FontSize="13"
                               TextAlignment="Center"/>

                    <Rectangle x:Name="FoupReturnModule"
                               Canvas.Left="52" Canvas.Top="390"
                               Width="128" Height="110"
                               RadiusX="10" RadiusY="10"
                               Fill="#162C3C"
                               Stroke="#5484A0"
                               StrokeThickness="2"/>
                    <TextBlock Canvas.Left="69" Canvas.Top="415"
                               Width="96"
                               Text="FOUP Return"
                               Style="{StaticResource ModuleLabelStyle}"
                               FontSize="14"/>
                    <TextBlock Canvas.Left="70" Canvas.Top="445"
                               Width="92"
                               Text="UNLOAD"
                               Foreground="#9AC9DC"
                               FontSize="13"
                               TextAlignment="Center"/>

                    <Rectangle x:Name="AlignerModule"
                               Canvas.Left="220" Canvas.Top="254"
                               Width="128" Height="92"
                               RadiusX="10" RadiusY="10"
                               Fill="#162C3C"
                               Stroke="#5484A0"
                               StrokeThickness="2"/>
                    <TextBlock Canvas.Left="246" Canvas.Top="285"
                               Width="78"
                               Text="Aligner"
                               Style="{StaticResource ModuleLabelStyle}"/>

                    <Rectangle x:Name="LoadLockModule"
                               Canvas.Left="398" Canvas.Top="232"
                               Width="140" Height="136"
                               RadiusX="10" RadiusY="10"
                               Fill="#182F3D"
                               Stroke="#72A9C4"
                               StrokeThickness="2"/>
                    <Rectangle x:Name="LoadLockDoor"
                               Canvas.Left="392" Canvas.Top="256"
                               Width="8" Height="88"
                               RadiusX="3" RadiusY="3"
                               Fill="{StaticResource ErrorBrush}"/>
                    <TextBlock Canvas.Left="421" Canvas.Top="270"
                               Width="92"
                               Text="Load Lock"
                               Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock x:Name="DoorStatusText"
                               Canvas.Left="425" Canvas.Top="306"
                               Width="84"
                               Text="DOOR CLOSED"
                               Foreground="#FF8A96"
                               FontSize="12"
                               FontWeight="Bold"
                               TextAlignment="Center"/>

                    <!-- Transfer module and robot arm -->
                    <Ellipse Canvas.Left="458" Canvas.Top="198" Width="250" Height="250"
                             Stroke="#20485F"
                             StrokeThickness="2"
                             Fill="#0A1927"/>
                    <Ellipse Canvas.Left="538" Canvas.Top="278" Width="90" Height="90"
                             Stroke="#4C778D"
                             StrokeThickness="2"
                             Fill="#132D40"/>
                    <TextBlock Canvas.Left="520" Canvas.Top="374"
                               Width="130"
                               Text="Transfer Robot"
                               Foreground="#9AC9DC"
                               FontSize="13"
                               FontWeight="Bold"
                               TextAlignment="Center"/>
                    <Line x:Name="RobotArmLine"
                          X1="583" Y1="323"
                          X2="714" Y2="323"
                          Stroke="{StaticResource AmberBrush}"
                          StrokeThickness="12"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round">
                        <Line.RenderTransform>
                            <RotateTransform x:Name="RobotArmRotateTransform"
                                             Angle="180"
                                             CenterX="583"
                                             CenterY="323"/>
                        </Line.RenderTransform>
                    </Line>
                    <Ellipse Canvas.Left="568" Canvas.Top="308" Width="30" Height="30"
                             Fill="#FFC857"
                             Stroke="#FFE7A6"
                             StrokeThickness="2"/>

                    <!-- Process modules -->
                    <Rectangle x:Name="PM2Module"
                               Canvas.Left="628" Canvas.Top="86"
                               Width="150" Height="112"
                               RadiusX="10" RadiusY="10"
                               Fill="#152B3A"
                               Stroke="#567F96"
                               StrokeThickness="2"/>
                    <Rectangle x:Name="PM2ProgressFill"
                               Canvas.Left="640" Canvas.Top="174"
                               Width="0" Height="10"
                               Fill="{StaticResource GoodBrush}"/>
                    <TextBlock Canvas.Left="646" Canvas.Top="113"
                               Width="114"
                               Text="PM2 Etch"
                               Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock Canvas.Left="648" Canvas.Top="144"
                               Width="110"
                               Text="PROCESS"
                               Foreground="#83AEC1"
                               FontSize="12"
                               TextAlignment="Center"/>

                    <Rectangle x:Name="PM3Module"
                               Canvas.Left="794" Canvas.Top="248"
                               Width="150" Height="112"
                               RadiusX="10" RadiusY="10"
                               Fill="#152B3A"
                               Stroke="#567F96"
                               StrokeThickness="2"/>
                    <Rectangle x:Name="PM3ProgressFill"
                               Canvas.Left="806" Canvas.Top="336"
                               Width="0" Height="10"
                               Fill="{StaticResource GoodBrush}"/>
                    <TextBlock Canvas.Left="812" Canvas.Top="275"
                               Width="114"
                               Text="PM3 Etch"
                               Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock Canvas.Left="814" Canvas.Top="306"
                               Width="110"
                               Text="PROCESS"
                               Foreground="#83AEC1"
                               FontSize="12"
                               TextAlignment="Center"/>

                    <Rectangle x:Name="PM4Module"
                               Canvas.Left="628" Canvas.Top="428"
                               Width="150" Height="112"
                               RadiusX="10" RadiusY="10"
                               Fill="#152B3A"
                               Stroke="#567F96"
                               StrokeThickness="2"/>
                    <Rectangle x:Name="PM4ProgressFill"
                               Canvas.Left="640" Canvas.Top="516"
                               Width="0" Height="10"
                               Fill="{StaticResource GoodBrush}"/>
                    <TextBlock Canvas.Left="646" Canvas.Top="455"
                               Width="114"
                               Text="PM4 Etch"
                               Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock Canvas.Left="648" Canvas.Top="486"
                               Width="110"
                               Text="PROCESS"
                               Foreground="#83AEC1"
                               FontSize="12"
                               TextAlignment="Center"/>

                    <Rectangle x:Name="PM1Module"
                               Canvas.Left="424" Canvas.Top="86"
                               Width="150" Height="112"
                               RadiusX="10" RadiusY="10"
                               Fill="#152B3A"
                               Stroke="#567F96"
                               StrokeThickness="2"/>
                    <Rectangle x:Name="PM1ProgressFill"
                               Canvas.Left="436" Canvas.Top="174"
                               Width="0" Height="10"
                               Fill="{StaticResource GoodBrush}"/>
                    <TextBlock Canvas.Left="440" Canvas.Top="113"
                               Width="118"
                               Text="PM1 Strip"
                               Style="{StaticResource ModuleLabelStyle}"/>
                    <TextBlock Canvas.Left="443" Canvas.Top="144"
                               Width="112"
                               Text="STRIP"
                               Foreground="#83AEC1"
                               FontSize="12"
                               TextAlignment="Center"/>

                    <Rectangle x:Name="SideStorageModule"
                               Canvas.Left="812" Canvas.Top="428"
                               Width="132" Height="92"
                               RadiusX="10" RadiusY="10"
                               Fill="#162C3C"
                               Stroke="#5484A0"
                               StrokeThickness="2"/>
                    <TextBlock Canvas.Left="823" Canvas.Top="455"
                               Width="110"
                               Text="Side Storage"
                               Style="{StaticResource ModuleLabelStyle}"
                               FontSize="14"/>

                    <!-- Transfer tracks -->
                    <Path Stroke="#244A5F"
                          StrokeThickness="4"
                          StrokeDashArray="5,5"
                          Data="M 116 278 L 284 300 L 468 300 L 583 323 L 704 142 M 583 323 L 870 304 M 583 323 L 704 484 M 583 323 L 500 142 M 468 300 L 116 445"/>

                    <Ellipse x:Name="WaferEllipse"
                             Canvas.Left="99" Canvas.Top="261"
                             Width="36" Height="36"
                             Stroke="#EFFFFF"
                             StrokeThickness="2">
                        <Ellipse.Fill>
                            <RadialGradientBrush GradientOrigin="0.35,0.3">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#9CEBFF" Offset="0.52"/>
                                <GradientStop Color="#3AA7D7" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#4AE7FF"
                                              BlurRadius="18"
                                              ShadowDepth="0"
                                              Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <Ellipse x:Name="RobotCarrierGlow"
                             Canvas.Left="690" Canvas.Top="305"
                             Width="34" Height="34"
                             Stroke="#FFE7A6"
                             StrokeThickness="2"
                             Fill="#30FFC857"
                             Opacity="0.65"/>
                </Canvas>
            </Viewbox>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="STATUS PANEL"
                               Foreground="{StaticResource CyanBrush}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Equipment State" Style="{StaticResource StatusLabelStyle}"/>
                    <TextBlock x:Name="EquipmentStateText" Text="IDLE" Style="{StaticResource StatusValueStyle}"/>

                    <TextBlock Text="Current Step" Style="{StaticResource StatusLabelStyle}"/>
                    <TextBlock x:Name="CurrentStepText" Text="Ready" Style="{StaticResource StatusValueStyle}" FontSize="18"/>

                    <TextBlock Text="Current Wafer Location" Style="{StaticResource StatusLabelStyle}"/>
                    <TextBlock x:Name="WaferLocationText" Text="FOUP A" Style="{StaticResource StatusValueStyle}" FontSize="18"/>

                    <TextBlock Text="Active Module" Style="{StaticResource StatusLabelStyle}"/>
                    <TextBlock x:Name="ActiveModuleText" Text="None" Style="{StaticResource StatusValueStyle}" FontSize="18"/>

                    <TextBlock Text="Chamber Progress" Style="{StaticResource StatusLabelStyle}"/>
                    <ProgressBar x:Name="ChamberProgressBar"
                                 Height="22"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Foreground="{StaticResource GoodBrush}"
                                 Background="#07131F"
                                 BorderBrush="#345A72"
                                 BorderThickness="1"/>
                    <TextBlock x:Name="ChamberProgressText"
                               Text="0%"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0"/>

                    <TextBlock Text="Robot Status" Style="{StaticResource StatusLabelStyle}"/>
                    <TextBlock x:Name="RobotStatusText" Text="Standby" Style="{StaticResource StatusValueStyle}" FontSize="18"/>

                    <TextBlock Text="Interlock Status" Style="{StaticResource StatusLabelStyle}"/>
                    <Border BorderBrush="#34694D"
                            BorderThickness="1"
                            Background="#0D2C21"
                            CornerRadius="6"
                            Padding="10,6"
                            Margin="0,0,0,12">
                        <TextBlock x:Name="InterlockStatusText"
                                   Text="DISPLAY ONLY - ALL CONDITIONS OK"
                                   Foreground="{StaticResource GoodBrush}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <WrapPanel Margin="0,14,0,0">
                        <Button x:Name="StartDemoButton"
                                Content="Start Demo"
                                Style="{StaticResource DemoButtonStyle}"
                                Click="StartDemo_Click"/>
                        <Button x:Name="PauseButton"
                                Content="Pause"
                                Style="{StaticResource DemoButtonStyle}"
                                Click="Pause_Click"/>
                        <Button Content="Reset"
                                Style="{StaticResource DemoButtonStyle}"
                                Click="Reset_Click"/>
                    </WrapPanel>
                    <WrapPanel Margin="0,10,0,0">
                        <Button Content="Inject Error"
                                Style="{StaticResource DemoButtonStyle}"
                                Background="#4A1D2A"
                                BorderBrush="#8C4555"
                                Click="InjectError_Click"/>
                        <Button Content="Clear Error"
                                Style="{StaticResource DemoButtonStyle}"
                                Click="ClearError_Click"/>
                    </WrapPanel>

                    <Border Background="#091622"
                            BorderBrush="#25485D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,18,0,0">
                        <TextBlock Text="This window does not connect to EtherCAT, PLC, Flask, or DB. It is a visual demo only."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="EVENT LOG"
                           Foreground="{StaticResource CyanBrush}"
                           FontSize="16"
                           FontWeight="Bold"/>
                <ListBox x:Name="EventLogList"
                         Grid.Row="1"
                         Background="#07131F"
                         BorderBrush="#25485D"
                         BorderThickness="1"
                         Foreground="#DCEFFF"
                         FontFamily="Consolas"
                         FontSize="14"
                         Padding="8"/>
            </Grid>
        </Border>
    </Grid>
</Window>
