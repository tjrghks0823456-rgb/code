<UserControl x:Class="etch_ui.Controls.ProcessStepLadderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="100">
    <Border Background="#F8FAFC" BorderBrush="{StaticResource HmiBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
        <StackPanel x:Name="StepsPanel">
            <TextBlock x:Name="Step0" Text="① LL 대기" FontSize="12" Margin="0,3"/>
            <TextBlock x:Name="Step1" Text="② LL 준비" FontSize="12" Margin="0,3"/>
            <TextBlock x:Name="Step2" Text="③ Chamber 운전" FontSize="12" Margin="0,3"/>
            <TextBlock x:Name="Step3" Text="④ 경고/복구" FontSize="12" Margin="0,3"/>
            <TextBlock x:Name="Step4" Text="⑤ 점검/알람" FontSize="12" Margin="0,3"/>
        </StackPanel>
    </Border>
</UserControl>
