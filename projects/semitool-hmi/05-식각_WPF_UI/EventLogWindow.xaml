<Window x:Class="etch_ui.EventLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="이벤트 로그 (SQLite)"
        Height="520"
        Width="780"
        MinHeight="400"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource HmiFont}"
        Background="{StaticResource HmiCanvasBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="이벤트 로그" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HmiTextPrimaryBrush}"/>
            <TextBlock Text="SQLite event_logs — 상태 전이·알람·조작 (최근 200건)"
                       Style="{StaticResource HmiCardSubtitle}"/>
        </StackPanel>
        <Border Grid.Row="1" Style="{StaticResource HmiCard}" Padding="10">
            <DataGrid x:Name="GrdEvents" Style="{StaticResource HmiDataGrid}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="시간" Binding="{Binding CreatedAtDisplay}" Width="150"/>
                    <DataGridTextColumn Header="사용자" Binding="{Binding Username}" Width="90"/>
                    <DataGridTextColumn Header="상태" Binding="{Binding State}" Width="80"/>
                    <DataGridTextColumn Header="코드" Binding="{Binding Code}" Width="60"/>
                    <DataGridTextColumn Header="메시지" Binding="{Binding Message}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="새로고침" Style="{StaticResource HmiSecondaryButton}" Margin="0,0,8,0" Click="BtnRefresh_Click"/>
            <Button Content="닫기" Style="{StaticResource HmiPrimaryButton}" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
