<UserControl x:Class="etch_ui.Equipment.Views.EquipmentSchematicControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:etch_ui.Equipment.Converters"
             xmlns:layout="clr-namespace:etch_ui.Equipment.Layout"
             MinHeight="420">
    <UserControl.Resources>
        <conv:BoolToDoorBrushConverter x:Key="BoolToDoorBrush"/>
        <conv:BoolToDoorTextConverter x:Key="BoolToDoorText"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <LinearGradientBrush x:Key="SteelPanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F8FAFC" Offset="0"/>
            <GradientStop Color="#E2E8F0" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="ModuleBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,4,4,0"/>
        </Style>
    </UserControl.Resources>
    <Border Background="#F1F5F9" CornerRadius="10" BorderBrush="{StaticResource HmiBorderBrush}" BorderThickness="1" Padding="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="4,2,4,8">
                <TextBlock Text="클러스터 툴 도식 (가상 TM)" Style="{StaticResource HmiCardTitle}"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding ServoHint}" Style="{StaticResource HmiCaption}"/>
            </DockPanel>
            <Viewbox Grid.Row="1" Stretch="Uniform">
                <Canvas x:Name="LayoutCanvas"
                        Width="{x:Static layout:EquipmentLayoutMetrics.DesignWidth}"
                        Height="{x:Static layout:EquipmentLayoutMetrics.DesignHeight}"
                        Background="#DCE5EF">

                    <Rectangle Width="980" Height="660" Fill="#E8EEF4"/>
                    <Rectangle Width="980" Height="660" Stroke="#C7D2DF" StrokeThickness="1"/>

                    <Polyline x:Name="MainTrack" Stroke="#94A3B8" StrokeThickness="5" Opacity="0.5"/>
                    <Polyline x:Name="MainTrackDash" Stroke="#2563EB" StrokeThickness="2" Opacity="0.45"
                              StrokeDashArray="6,5"/>
                    <Canvas x:Name="PmSpokesLayer"/>

                    <!-- EFEM -->
                    <Border x:Name="EfemBox" Background="#F1F5F9" BorderBrush="{Binding EfemPanel.StatusBrush}"
                            BorderThickness="2.5" CornerRadius="8">
                        <Grid>
                            <Border Background="#334155" CornerRadius="6,6,0,0" Padding="8,5" VerticalAlignment="Top">
                                <TextBlock Text="EFEM · 대기압" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Style="{StaticResource ModuleBadge}" Background="{Binding EfemPanel.StatusBrush}">
                                <TextBlock Text="{Binding EfemPanel.Badge}" Foreground="White" FontSize="8" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Aligner -->
                    <Border x:Name="AlignerBox" Background="{StaticResource SteelPanelBrush}"
                            BorderBrush="{Binding AlignerPanel.StatusBrush}" BorderThickness="2" CornerRadius="6">
                        <Grid>
                            <TextBlock Text="Aligner" FontSize="9" FontWeight="Bold" Foreground="#1E293B"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="18" Height="18" Fill="{Binding WaferBrush}" Stroke="#B45309" StrokeThickness="1.2"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Visibility="{Binding AlignerHasWafer, Converter={StaticResource BoolVis}}"/>
                            <Border Style="{StaticResource ModuleBadge}" Background="{Binding AlignerPanel.StatusBrush}">
                                <TextBlock Text="{Binding AlignerPanel.Badge}" Foreground="White" FontSize="7" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Side storage -->
                    <Border x:Name="SideStorageBox" Background="{StaticResource SteelPanelBrush}"
                            BorderBrush="{Binding SideStoragePanel.StatusBrush}" BorderThickness="2" CornerRadius="6">
                        <Grid>
                            <TextBlock Text="Side Stg" FontSize="8" FontWeight="Bold" Foreground="#1E293B"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="16" Height="16" Fill="{Binding WaferBrush}" Stroke="#B45309" StrokeThickness="1.2"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,0"
                                     Visibility="{Binding SideStorageHasWafer, Converter={StaticResource BoolVis}}"/>
                            <Border Style="{StaticResource ModuleBadge}" Background="{Binding SideStoragePanel.StatusBrush}">
                                <TextBlock Text="{Binding SideStoragePanel.Badge}" Foreground="White" FontSize="7" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Load ports -->
                    <Border x:Name="LoadPort1Box" Background="#E5E7EB" BorderBrush="{Binding LoadPort1Panel.StatusBrush}"
                            BorderThickness="2" CornerRadius="6">
                        <Grid>
                            <TextBlock Text="LP1" FontSize="9" FontWeight="Bold" Foreground="#1E293B"
                                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0"/>
                            <Ellipse Width="20" Height="20" Fill="{Binding WaferBrush}" Stroke="#B45309" StrokeThickness="1.2"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Visibility="{Binding FoupAHasWafer, Converter={StaticResource BoolVis}}"/>
                            <Border Style="{StaticResource ModuleBadge}" Background="{Binding LoadPort1Panel.StatusBrush}">
                                <TextBlock Text="{Binding LoadPort1Panel.Badge}" Foreground="White" FontSize="7" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>
                    <Border x:Name="LoadPort2Box" Background="#E5E7EB" BorderBrush="{Binding LoadPort2Panel.StatusBrush}"
                            BorderThickness="2" CornerRadius="6">
                        <Grid>
                            <TextBlock Text="LP2" FontSize="9" FontWeight="Bold" Foreground="#1E293B"
                                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0"/>
                            <Ellipse Width="20" Height="20" Fill="{Binding WaferBrush}" Stroke="#B45309" StrokeThickness="1.2"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Visibility="{Binding FoupBHasWafer, Converter={StaticResource BoolVis}}"/>
                            <Border Style="{StaticResource ModuleBadge}" Background="{Binding LoadPort2Panel.StatusBrush}">
                                <TextBlock Text="{Binding LoadPort2Panel.Badge}" Foreground="White" FontSize="7" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>
                    <Border x:Name="LoadPort3Box" Background="#E5E7EB" BorderBrush="{Binding LoadPort3Panel.StatusBrush}"
                            BorderThickness="2" CornerRadius="6">
                        <Grid>
                            <TextBlock Text="LP3" FontSize="9" FontWeight="Bold" Foreground="#1E293B"
                                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0"/>
                            <Ellipse Width="20" Height="20" Fill="{Binding WaferBrush}" Stroke="#B45309" StrokeThickness="1.2"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Visibility="{Binding FoupCHasWafer, Converter={StaticResource BoolVis}}"/>
                            <Border Style="{StaticResource ModuleBadge}" Background="{Binding LoadPort3Panel.StatusBrush}">
                                <TextBlock Text="{Binding LoadPort3Panel.Badge}" Foreground="White" FontSize="7" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- BM / Load lock -->
                    <Border x:Name="LoadLockBox" Background="{StaticResource SteelPanelBrush}"
                            BorderBrush="{Binding BufferPanel.StatusBrush}" BorderThickness="2.5" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Background="#334155" CornerRadius="6,6,0,0" Padding="6,4">
                                <TextBlock Text="BM · Load Lock" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="1" Margin="12,10,12,8" Background="#CBD5E1" CornerRadius="5"
                                    BorderBrush="{Binding LoadLockDoorClosed, Converter={StaticResource BoolToDoorBrush}}" BorderThickness="2"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                                <Ellipse Width="8" Height="8" Fill="{Binding LoadLockDoorClosed, Converter={StaticResource BoolToDoorBrush}}"/>
                                <TextBlock Margin="5,0,0,0" FontSize="8" FontWeight="SemiBold" Foreground="#334155"
                                           Text="{Binding LoadLockDoorClosed, Converter={StaticResource BoolToDoorText}}"/>
                            </StackPanel>
                            <Border Style="{StaticResource ModuleBadge}" Background="{Binding BufferPanel.StatusBrush}">
                                <TextBlock Text="{Binding BufferPanel.Badge}" Foreground="White" FontSize="7" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- PM1 Strip -->
                    <Border x:Name="ChamberABox" Background="{StaticResource SteelPanelBrush}"
                            BorderBrush="{Binding Pm1Panel.StatusBrush}" BorderThickness="2.5" CornerRadius="8">
                        <Grid>
                            <Rectangle Height="8" VerticalAlignment="Top" Fill="{Binding ChamberALampBrush}"/>
                            <Rectangle Height="16" VerticalAlignment="Top" Margin="10,12,10,0" RadiusX="3" RadiusY="3"
                                       Fill="{Binding ChamberADoorClosed, Converter={StaticResource BoolToDoorBrush}}">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="RenderTransform"><Setter.Value><TranslateTransform Y="0"/></Setter.Value></Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ChamberADoorClosed}" Value="False">
                                                <Setter Property="RenderTransform"><Setter.Value><TranslateTransform Y="-12"/></Setter.Value></Setter>
                                                <Setter Property="Opacity" Value="0.3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            <TextBlock Text="PM1 · Strip" FontWeight="Bold" FontSize="9" Margin="0,34,0,0"
                                       HorizontalAlignment="Center" Foreground="#1E293B"/>
                            <Ellipse Width="22" Height="22" Margin="0,52,0,0"
                                     HorizontalAlignment="Center" VerticalAlignment="Top"
                                     Visibility="{Binding ChamberAHasWafer, Converter={StaticResource BoolVis}}"
                                     Fill="{Binding WaferBrush}" Stroke="#B45309" StrokeThickness="1.4"/>
                            <Border Style="{StaticResource ModuleBadge}" Background="{Binding Pm1Panel.StatusBrush}">
                                <TextBlock Text="{Binding Pm1Panel.Badge}" Foreground="White" FontSize="7" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- PM2 Poly -->
                    <Border x:Name="ChamberBBox" Background="{StaticResource SteelPanelBrush}"
                            BorderBrush="{Binding Pm2Panel.StatusBrush}" BorderThickness="2.5" CornerRadius="8">
                        <Grid>
                            <Rectangle Height="8" VerticalAlignment="Top" Fill="{Binding ChamberBLampBrush}"/>
                            <Rectangle Width="14" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Stretch"
                                       RadiusX="3" RadiusY="3" Fill="{Binding ChamberBDoorClosed, Converter={StaticResource BoolToDoorBrush}}">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Margin" Value="10,14,0,14"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ChamberBDoorClosed}" Value="False">
                                                <Setter Property="Margin" Value="2,14,0,14"/>
                                                <Setter Property="Opacity" Value="0.3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            <TextBlock Text="PM2 · Etch" FontWeight="Bold" FontSize="9" Margin="18,34,0,0"
                                       HorizontalAlignment="Center" Foreground="#1E293B"/>
                            <Ellipse Width="22" Height="22" Margin="0,52,0,0"
                                     HorizontalAlignment="Center" VerticalAlignment="Top"
                                     Visibility="{Binding ChamberBHasWafer, Converter={StaticResource BoolVis}}"
                                     Fill="{Binding WaferBrush}" Stroke="#B45309" StrokeThickness="1.4"/>
                            <Border Style="{StaticResource ModuleBadge}" Background="{Binding Pm2Panel.StatusBrush}">
                                <TextBlock Text="{Binding Pm2Panel.Badge}" Foreground="White" FontSize="7" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- PM3 Poly -->
                    <Border x:Name="ChamberCBox" Background="{StaticResource SteelPanelBrush}"
                            BorderBrush="{Binding Pm3Panel.StatusBrush}" BorderThickness="2.5" CornerRadius="8">
                        <Grid>
                            <Rectangle Height="8" VerticalAlignment="Top" Fill="{Binding ChamberCLampBrush}"/>
                            <Rectangle Width="14" HorizontalAlignment="Left" Margin="10,0,0,0"
                                       RadiusX="3" RadiusY="3" Fill="{Binding ChamberCDoorClosed, Converter={StaticResource BoolToDoorBrush}}">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Margin" Value="10,14,0,14"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ChamberCDoorClosed}" Value="False">
                                                <Setter Property="Margin" Value="2,14,0,14"/>
                                                <Setter Property="Opacity" Value="0.3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            <TextBlock Text="PM3 · Etch" FontWeight="Bold" FontSize="9" Margin="18,34,0,0"
                                       HorizontalAlignment="Center" Foreground="#1E293B"/>
                            <Ellipse Width="22" Height="22" Margin="0,52,0,0"
                                     HorizontalAlignment="Center" VerticalAlignment="Top"
                                     Visibility="{Binding ChamberCHasWafer, Converter={StaticResource BoolVis}}"
                                     Fill="{Binding WaferBrush}" Stroke="#B45309" StrokeThickness="1.4"/>
                            <Border Style="{StaticResource ModuleBadge}" Background="{Binding Pm3Panel.StatusBrush}">
                                <TextBlock Text="{Binding Pm3Panel.Badge}" Foreground="White" FontSize="7" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- PM4 Etch -->
                    <Border x:Name="Pm4Box" Background="{StaticResource SteelPanelBrush}"
                            BorderBrush="{Binding Pm4Panel.StatusBrush}" BorderThickness="2.5" CornerRadius="8">
                        <Grid>
                            <Rectangle Height="8" VerticalAlignment="Top" Fill="{Binding ChamberDLampBrush}"/>
                            <Rectangle Height="16" VerticalAlignment="Top" Margin="10,12,10,0" RadiusX="3" RadiusY="3"
                                       Fill="{Binding ChamberDDoorClosed, Converter={StaticResource BoolToDoorBrush}}">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ChamberDDoorClosed}" Value="False">
                                                <Setter Property="RenderTransform"><Setter.Value><TranslateTransform Y="-12"/></Setter.Value></Setter>
                                                <Setter Property="Opacity" Value="0.3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            <TextBlock Text="PM4 · Etch" FontWeight="Bold" FontSize="9" Margin="0,34,0,0"
                                       HorizontalAlignment="Center" Foreground="#1E293B"/>
                            <Ellipse Width="22" Height="22" Margin="0,52,0,0"
                                     HorizontalAlignment="Center" VerticalAlignment="Top"
                                     Visibility="{Binding ChamberDHasWafer, Converter={StaticResource BoolVis}}"
                                     Fill="{Binding WaferBrush}" Stroke="#B45309" StrokeThickness="1.4"/>
                            <Border Style="{StaticResource ModuleBadge}" Background="{Binding Pm4Panel.StatusBrush}">
                                <TextBlock Text="{Binding Pm4Panel.Badge}" Foreground="White" FontSize="7" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- EFEM TM (대기압) -->
                    <Grid x:Name="EfemRobotHost" Width="76" Height="76" Visibility="Collapsed">
                        <Grid.RenderTransform>
                            <RotateTransform x:Name="EfemRotate" Angle="0" CenterX="38" CenterY="38"/>
                        </Grid.RenderTransform>
                        <Ellipse Width="76" Height="76" Fill="#0D9488" Opacity="0.18" Stroke="#0F766E" StrokeThickness="2"/>
                        <Ellipse Width="54" Height="54" Fill="#14B8A6" Stroke="#0F766E" StrokeThickness="1.8"/>
                        <Rectangle x:Name="EfemBladeRect" Fill="#57534E" RadiusX="3" RadiusY="3"
                                   Height="12" VerticalAlignment="Center" HorizontalAlignment="Left"
                                   Margin="38,32,0,32"/>
                        <Ellipse x:Name="WaferOnEfemBlade" Width="14" Height="14" Fill="{Binding WaferBrush}"
                                 Stroke="#B45309" StrokeThickness="1.2"
                                 HorizontalAlignment="Left" VerticalAlignment="Center"
                                 Margin="6,0,0,0" Visibility="Collapsed"/>
                        <TextBlock Text="EFEM·TM" Foreground="White" FontWeight="Bold" FontSize="8"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- TM (진공) -->
                    <Grid x:Name="TmHost" Width="112" Height="112">
                        <Grid.RenderTransform>
                            <RotateTransform x:Name="TmRotate" Angle="0" CenterX="56" CenterY="56"/>
                        </Grid.RenderTransform>
                        <Ellipse Width="112" Height="112" Fill="#1E3A8A" Opacity="0.14" Stroke="#1E40AF" StrokeThickness="2.5"/>
                        <Ellipse Width="82" Height="82" Fill="#1D4ED8" Stroke="#1E40AF" StrokeThickness="2"/>
                        <Rectangle x:Name="BladeRect" Fill="#475569" RadiusX="4" RadiusY="4"
                                   Height="16" VerticalAlignment="Center" HorizontalAlignment="Left"
                                   Margin="56,48,0,48"/>
                        <Ellipse x:Name="WaferOnBlade" Width="17" Height="17" Fill="{Binding WaferBrush}"
                                 Stroke="#B45309" StrokeThickness="1.3"
                                 HorizontalAlignment="Left" VerticalAlignment="Center"
                                 Margin="8,0,0,0" Visibility="Collapsed"/>
                        <TextBlock Text="TM·진공" Foreground="White" FontWeight="Bold" FontSize="11"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border Style="{StaticResource ModuleBadge}" Background="{Binding TmPanel.StatusBrush}" Margin="0,6,6,0">
                            <TextBlock Text="{Binding TmPanel.Badge}" Foreground="White" FontSize="7" FontWeight="Bold"/>
                        </Border>
                    </Grid>

                    <TextBlock x:Name="TmLabel" Text="{Binding TmRegionLabel}"
                               FontSize="10" Foreground="#334155" FontWeight="SemiBold"/>

                    <Border Canvas.Left="12" Canvas.Top="600" Width="240" Height="72"
                            Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1.2" CornerRadius="8">
                        <StackPanel Margin="10,8">
                            <TextBlock Text="EFEM·TM: LP→Aligner→BM  |  TM: PM2~4→PM1→BM  |  EFEM·TM: Side Stg→LP" FontSize="7" FontWeight="Bold" Foreground="#334155"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <Ellipse Width="9" Height="9" Fill="#16A34A"/>
                                <TextBlock Text=" 도어 닫힘" FontSize="8" Foreground="#334155"/>
                                <Ellipse Width="9" Height="9" Fill="#DC2626" Margin="10,0,0,0"/>
                                <TextBlock Text=" 도어 열림(가상)" FontSize="8" Foreground="#334155"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Canvas>
            </Viewbox>
        </Grid>
    </Border>
</UserControl>
